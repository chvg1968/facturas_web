# Airtable Personal Access Token (https://airtable.com/create/tokens)
AIRTABLE_API_KEY=

# ID de la base donde vive la tabla "Facturas" (empieza con "app...")
AIRTABLE_BASE_ID=

# Nombre de la tabla en Airtable
AIRTABLE_TABLE_NAME=Facturas

# Nombre exacto del campo de adjunto en Airtable
AIRTABLE_ATTACHMENT_FIELD=Doc
